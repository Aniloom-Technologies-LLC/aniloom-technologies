---
import BaseLayout from "../layouts/BaseLayout.astro";
import FloatingLines from "../components/FloatingLines";
import GradientText from "../components/GradientText";
---

<BaseLayout title="Unity Assets — Aniloom Technologies">
  <main class="content content--lifted page-stage page-stage--lines">
    <FloatingLines client:load density={12} />
    <section>
      <div class="panel panel--wide">
        <span class="section-caption">Unity Assets</span>
        <h2><GradientText client:load>Unity tools built for production clarity.</GradientText></h2>
        <p>Technical art utilities and runtime helpers designed to remove friction from teams shipping polished interactive work.</p>
        <div class="cards">
          <article class="card">
            <h3>Aniloom TAC</h3>
            <p>Tween Animation Controller for orchestrated UI, transitions, and camera beats across cinematic product surfaces.</p>
            <span class="placeholder-button">Motion systems</span>
          </article>
          <article class="card">
            <h3>Building Shader Pack</h3>
            <p>GPU-aware facade materials and atmosphere-sensitive lighting cues for large urban scenes and branded worlds.</p>
            <span class="placeholder-button">Environment rendering</span>
          </article>
          <article class="card">
            <h3>UI Animation Utilities</h3>
            <p>Reusable motion primitives that make interfaces feel intentional instead of mechanically assembled.</p>
            <span class="placeholder-button">Interface motion</span>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
