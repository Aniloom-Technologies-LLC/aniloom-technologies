---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Unity Assets — Aniloom Technologies">
  <main class="content content--lifted">
    <section>
      <div class="panel">
        <span class="section-caption">Unity Assets</span>
        <h2>Our Unity and technical art tools.</h2>
        <p>Tools engineered for production pipelines and cinematic results.</p>
        <div class="cards">
          <article class="card">
            <h3>Aniloom TAC</h3>
            <p>Tween Animation Controller for orchestrated UI and camera beats.</p>
            <span class="placeholder-button">Details soon</span>
          </article>
          <article class="card">
            <h3>Building Shader Pack</h3>
            <p>GPU-friendly facades with atmosphere-aware lighting cues.</p>
            <span class="placeholder-button">Details soon</span>
          </article>
          <article class="card">
            <h3>UI Animation Utilities</h3>
            <p>Curated animation presets for immersive interface motion.</p>
            <span class="placeholder-button">Details soon</span>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
