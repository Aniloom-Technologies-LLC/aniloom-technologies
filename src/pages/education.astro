---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Education — Aniloom Technologies">
  <main class="content content--lifted">
    <section>
      <div class="panel">
        <span class="section-caption">Education</span>
        <h2>Learning resources, internal tools, and tutorials.</h2>
        <p>Coming soon. Meanwhile, preview what we are curating.</p>
        <div class="cards">
          <article class="card">
            <h3>Workflow Playbooks</h3>
            <p>Deep dives on AI-assisted production pipelines.</p>
            <span class="placeholder-button">Preview soon</span>
          </article>
          <article class="card">
            <h3>Unity Tech Art Labs</h3>
            <p>Hands-on labs blending procedural VFX and automation.</p>
            <span class="placeholder-button">Preview soon</span>
          </article>
          <article class="card">
            <h3>Systems Thinking Streams</h3>
            <p>Live streams exploring architecture decisions in the open.</p>
            <span class="placeholder-button">Preview soon</span>
          </article>
          <article class="card">
            <h3>AI Integration Guides</h3>
            <p>Guided playbooks for connecting assistants to real products.</p>
            <span class="placeholder-button">Preview soon</span>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
