---
import BaseLayout from "../layouts/BaseLayout.astro";
import GradientText from "../components/GradientText";
---

<BaseLayout
  title="Aniloom Technologies"
  scripts={[{ src: "/assets/js/main.js", type: "module" }]}
  navItems={[
    { href: "/education/", label: "Education" },
    { href: "/unity-assets/", label: "Unity Assets" },
    { href: "/insights/", label: "Insights" },
    { href: "#contact", label: "Contact Us" },
  ]}
>
  <div class="scene-layer">
    <canvas id="scene-canvas"></canvas>
  </div>

  <main class="content">
    <section id="intro-orbit" data-scene-step="orbit">
      <div class="panel hero-panel">
        <span class="section-caption">Intro / Orbit</span>
        <h1><GradientText>Aniloom Technologies</GradientText></h1>
        <p class="hero-lead">AI-native product engineering for founders, operators, and ambitious teams.</p>
        <p>We design and ship web, mobile, game, and on-chain software with a bias for speed, clarity, and cinematic execution.</p>
      </div>
    </section>

    <section id="dome-core" data-scene-step="core">
      <div class="panel">
        <span class="section-caption">Dome 0</span>
        <h2><GradientText>AI-Driven Core</GradientText></h2>
        <p>Agent workflows, copilots, internal tools, and delivery systems that can survive real operational use.</p>
      </div>
    </section>

    <section id="dome-web" data-scene-step="web">
      <div class="panel">
        <span class="section-caption">Dome 1</span>
        <h2><GradientText>Web Platforms</GradientText></h2>
        <p>Fast, premium interfaces backed by stable APIs, durable admin surfaces, and measurable product logic.</p>
      </div>
    </section>

    <section id="dome-mobile" data-scene-step="mobile">
      <div class="panel">
        <span class="section-caption">Dome 2</span>
        <h2><GradientText>Mobile Apps</GradientText></h2>
        <p>Native-feeling mobile products for teams that need reliable delivery, not just prototype momentum.</p>
      </div>
    </section>

    <section id="dome-chain" data-scene-step="web3">
      <div class="panel">
        <span class="section-caption">Dome 3</span>
        <h2><GradientText>On-Chain Apps</GradientText></h2>
        <p>Interfaces and systems built on established networks where transparency, performance, and trust all matter.</p>
      </div>
    </section>

    <section id="dome-games" data-scene-step="games">
      <div class="panel">
        <span class="section-caption">Dome 4</span>
        <h2><GradientText>Games & Real-Time</GradientText></h2>
        <p>Unity pipelines, technical art, and immersive interfaces shaped for interactive products and branded experiences.</p>
      </div>
    </section>

    <section id="contact" data-scene-step="contact">
      <div class="panel">
        <h2><GradientText>Tell us what you’re building.</GradientText></h2>
        <p>Share a brief outline and we’ll craft a tailored response.</p>
        <a
          class="primary-action"
          href="mailto:hello@aniloom.tech?subject=Project%20estimate%20request&body=Hi%20Aniloom%20team%2C%20I%E2%80%99d%20like%20to%20estimate%20my%20project.%20It%20includes%3A%20"
        >
          Contact us
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
