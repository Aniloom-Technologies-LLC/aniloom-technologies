---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Blog — Aniloom Technologies">
  <main class="content content--lifted">
    <section>
      <div class="panel">
        <span class="section-caption">Journal</span>
        <h1>Blog & Articles</h1>
        <p>
          Notes on AI-assisted engineering, technical art, and product systems from the Aniloom
          studio.
        </p>
        <div class="cards">
          {posts.map((post) => (
            <article class="card">
              <span class="section-caption">{post.data.category}</span>
              <h2>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <p>{post.data.publishDate.toLocaleDateString("en-US", { dateStyle: "long" })}</p>
              <a class="primary-action" href={`/blog/${post.slug}/`}>Read article</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
