---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy — Aniloom Technologies">
  <main class="content content--lifted">
    <section>
      <article class="panel article-shell">
        <span class="section-caption">Legal</span>
        <h1>Privacy Policy</h1>
        <p>Effective date: March 19, 2026</p>
        <div class="article-content">
          <p>
            Aniloom Technologies LLC respects your privacy. This site is a marketing website and
            informational publication site. We keep data collection minimal.
          </p>
          <h2>Information We Collect</h2>
          <p>
            If you contact us by email, we receive the information you choose to send, such as your
            name, email address, company details, and project information.
          </p>
          <h2>Automatic Data</h2>
          <p>
            This site stores local browser preferences for theme selection. These preferences remain
            on your device and are not used to identify you personally.
          </p>
          <h2>How We Use Information</h2>
          <p>
            We use information you send us to respond to inquiries, evaluate project fit, and
            communicate about potential services.
          </p>
          <h2>Sharing</h2>
          <p>
            We do not sell personal information. We may share information with service providers
            involved in hosting, security, or communications when reasonably necessary to operate
            the site or respond to your request.
          </p>
          <h2>Data Retention</h2>
          <p>
            We retain inquiry emails and related business communications for as long as reasonably
            necessary for operations, legal compliance, or recordkeeping.
          </p>
          <h2>Your Choices</h2>
          <p>
            You may contact us at <a href="mailto:support@aniloom.tech">support@aniloom.tech</a> to
            request correction or deletion of information you have sent us, subject to legal or
            operational obligations.
          </p>
          <h2>Changes</h2>
          <p>
            We may update this policy from time to time. Material changes will be reflected on this
            page with an updated effective date.
          </p>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
