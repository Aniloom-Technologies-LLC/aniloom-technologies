---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FloatingLines from "../../components/FloatingLines";
import GradientText from "../../components/GradientText";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Insights — Aniloom Technologies">
  <main class="content content--lifted page-stage page-stage--lines">
    <FloatingLines
      client:load
      lineCount={[5, 7, 6]}
      lineDistance={[5, 7, 6]}
      linesGradient={["#89dbff", "#91a4ff", "#d6c6ff"]}
      bendStrength={-0.3}
    />
    <section>
      <div class="panel panel--wide">
        <span class="section-caption">Insights</span>
        <h1><GradientText client:load>Technical Notes From the Studio</GradientText></h1>
        <p>
          Practical writing on AI systems, technical art pipelines, and product engineering choices
          that affect real delivery.
        </p>
        <div class="cards">
          {posts.map((post) => (
            <article class="card">
              <span class="section-caption">{post.data.category}</span>
              <h2>
                <a href={`/insights/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <p>{post.data.publishDate.toLocaleDateString("en-US", { dateStyle: "long" })}</p>
              <a class="primary-action" href={`/insights/${post.slug}/`}>Read insight</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
