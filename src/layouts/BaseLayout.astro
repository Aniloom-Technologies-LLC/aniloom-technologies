---
import SplashCursor from "../components/SplashCursor";

interface NavItem {
  href: string;
  label: string;
}

interface FooterGroup {
  title: string;
  items: NavItem[];
}

interface ScriptItem {
  src: string;
  type?: "module";
}

interface Props {
  title: string;
  bodyClass?: string;
  headerVariant?: "default" | "island";
  brandHref?: string;
  navItems?: NavItem[];
  footerGroups?: FooterGroup[];
  scripts?: ScriptItem[];
}

const {
  title,
  bodyClass = "",
  headerVariant = "default",
  brandHref = "/",
  navItems = [
    { href: "/education/", label: "Education" },
    { href: "/unity-assets/", label: "Unity Assets" },
    { href: "/insights/", label: "Insights" },
    { href: "/#contact", label: "Contact Us" },
  ],
  footerGroups = [
    {
      title: "Company",
      items: [
        { href: "/", label: "Home" },
        { href: "/insights/", label: "Insights" },
        { href: "mailto:hello@aniloom.tech", label: "hello@aniloom.tech" },
      ],
    },
    {
      title: "Services",
      items: [
        { href: "/education/", label: "Education" },
        { href: "/unity-assets/", label: "Unity Assets" },
        { href: "/#contact", label: "Start a Project" },
      ],
    },
    {
      title: "Labs",
      items: [
        { href: "/world-clock/", label: "World Clock" },
        { href: "/life-weeks/", label: "Life Weeks" },
        { href: "/test-scene/", label: "3D Test" },
      ],
    },
    {
      title: "Legal",
      items: [
        { href: "/privacy-policy/", label: "Privacy Policy" },
        { href: "/terms-of-use/", label: "Terms of Use" },
      ],
    },
  ],
  scripts = [],
} = Astro.props;

const bodyClasses = ["theme-dark", bodyClass].filter(Boolean).join(" ");
---
<!DOCTYPE html>
<html lang="en" class="theme-dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body class={bodyClasses}>
    <SplashCursor
      client:load
      DYE_RESOLUTION={1024}
      SIM_RESOLUTION={96}
      SPLAT_RADIUS={0.12}
      SPLAT_FORCE={4200}
      COLOR_UPDATE_SPEED={6}
    />
    {
      headerVariant === "island" ? (
        <header class="island-header">
          <a class="floating-island floating-island--brand" href={brandHref}>Aniloom</a>
          <div class="floating-island floating-island--controls">
            <button class="switch theme-switch" data-theme-toggle type="button" aria-pressed="false">
              <span class="switch-track">
                <span class="switch-label" data-value="night" aria-hidden="true">
                  <img class="theme-icon" src="/assets/images/moon_icon.png" alt="" />
                </span>
                <span class="switch-label" data-value="day" aria-hidden="true">
                  <img class="theme-icon" src="/assets/images/sun_icon.png" alt="" />
                </span>
                <span class="switch-thumb"></span>
              </span>
            </button>
          </div>
        </header>
      ) : (
        <header class="site-header">
          <a class="site-brand" href={brandHref}>Aniloom</a>
          <nav class="site-nav">
            {navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
          <div class="header-controls">
            <button class="switch theme-switch" data-theme-toggle type="button" aria-pressed="false">
              <span class="switch-track">
                <span class="switch-label" data-value="night" aria-hidden="true">
                  <img class="theme-icon" src="/assets/images/moon_icon.png" alt="" />
                </span>
                <span class="switch-label" data-value="day" aria-hidden="true">
                  <img class="theme-icon" src="/assets/images/sun_icon.png" alt="" />
                </span>
                <span class="switch-thumb"></span>
              </span>
            </button>
          </div>
        </header>
      )
    }

    <div class="page-shell">
      <slot />
    </div>

    <div class="contact-modal" data-contact-modal hidden>
      <div class="contact-modal__backdrop" data-contact-close></div>
      <div
        class="contact-modal__content"
        role="dialog"
        aria-modal="true"
        aria-labelledby="contact-modal-title"
        tabindex="-1"
      >
        <button class="contact-modal__close" type="button" aria-label="Close contact form" data-contact-close>
          <span></span>
          <span></span>
        </button>
        <span class="section-caption">Contact</span>
        <h2 id="contact-modal-title">Start a Project</h2>
        <p>
          Share the essentials and we will reply with the most useful next step.
        </p>
        <form class="contact-form" data-contact-form>
          <label class="contact-field">
            <span>Name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>
          <label class="contact-field">
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
          <label class="contact-field contact-field--full">
            <span>Project outline</span>
            <textarea
              name="project"
              rows="5"
              placeholder="What are you building, what stage are you at, and what kind of help do you need?"
              required
            ></textarea>
          </label>
          <button class="primary-action" type="submit">Draft Email</button>
        </form>
      </div>
    </div>

    <footer class="site-footer">
      <div class="site-footer__grid">
        <div class="site-footer__brand">
          <a class="site-brand" href="/">Aniloom</a>
          <p>
            Aniloom Technologies LLC builds client-facing software, internal tooling, and
            interactive digital experiences.
          </p>
        </div>
        {
          footerGroups.map((group) => (
            <div class="site-footer__group">
              <h2>{group.title}</h2>
              <div class="site-footer__links">
                {group.items.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <div class="site-footer__bottom">
        <span>© 2026 Aniloom Technologies LLC</span>
      </div>
      <div class="site-footer__pull" data-footer-pull aria-hidden="true">
        <blockquote class="site-footer__quote" data-footer-quote>
          <p data-footer-quote-text></p>
          <cite data-footer-quote-source></cite>
        </blockquote>
      </div>
    </footer>

    <script src="/assets/js/theme.js" defer></script>
    <script src="/assets/js/contact-modal.js" defer></script>
    <script src="/assets/js/footer-pull.js" defer></script>
    {
      scripts.map((script) => (
        <script src={script.src} type={script.type} defer={script.type !== "module"}></script>
      ))
    }
  </body>
</html>
